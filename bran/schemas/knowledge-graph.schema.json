{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.alphazede.dev/bran/knowledge-graph/v1/schema.json",
  "title": "BRAN Knowledge Graph",
  "description": "Portable immutable graph evidence. Relationships and semantic facts are scanner-supplied evidence, not verified inference.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "nodes", "edges"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "nodes": {
      "type": "array",
      "maxItems": 1000000,
      "description": "Ordered lexicographically by stable node id.",
      "items": { "$ref": "#/$defs/node" }
    },
    "edges": {
      "type": "array",
      "maxItems": 1000000,
      "description": "Ordered lexicographically by stable edge id.",
      "items": { "$ref": "#/$defs/edge" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9./:_-]+$"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "locator"],
      "properties": {
        "source": { "type": "string", "minLength": 1, "maxLength": 128 },
        "locator": { "type": "string", "minLength": 1, "maxLength": 1024 }
      }
    },
    "fact_field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "values"],
      "properties": {
        "key": { "type": "string", "minLength": 1, "maxLength": 64 },
        "values": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "uniqueItems": true,
          "description": "Ordered lexicographically.",
          "items": { "type": "string", "minLength": 1, "maxLength": 256 }
        }
      }
    },
    "facts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["semantic_bytes", "fields"],
      "properties": {
        "semantic_bytes": { "type": "integer", "minimum": 0, "maximum": 8192 },
        "fields": {
          "type": "array",
          "maxItems": 32,
          "description": "Ordered lexicographically by key; UTF-8 keys plus values total at most semantic_bytes.",
          "items": { "$ref": "#/$defs/fact_field" }
        }
      }
    },
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "role", "provenance", "confidence", "facts"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "role": { "enum": ["document", "section", "symbol", "external", "entrypoint", "test", "generated", "archived"] },
        "provenance": { "$ref": "#/$defs/provenance" },
        "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
        "facts": { "$ref": "#/$defs/facts" }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "source", "target", "provenance", "confidence", "certainty", "relationship"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "source": { "$ref": "#/$defs/id" },
        "target": { "$ref": "#/$defs/id" },
        "provenance": { "$ref": "#/$defs/provenance" },
        "confidence": { "type": "integer", "minimum": 0, "maximum": 100 },
        "certainty": { "enum": ["known", "dynamic", "unknown", "missing-target"] },
        "relationship": { "enum": ["unspecified", "dependency", "implementation", "replacement", "supersedes", "validation", "reachability", "contradiction", "conflict"] }
      }
    }
  }
}
