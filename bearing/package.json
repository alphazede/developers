{
  "name": "@alphazede/bearing",
  "version": "0.1.0",
  "description": "Local browser control room for evidence-backed agent workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alphazede/developers.git"
  },
  "homepage": "https://github.com/alphazede/developers#readme",
  "bugs": {
    "url": "https://github.com/alphazede/developers/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist/",
    "assets/",
    "fixtures/fictional-b2b/",
    "README.md",
    "LICENSE",
    "SUBMISSION.md"
  ],
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "bin": {
    "bearing": "dist/cli.js"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "eval:native": "tsc && node dist/evaluation/cli.js native",
    "eval:skillsbench": "tsc && node dist/evaluation/cli.js skillsbench",
    "test:integration": "vitest run test/local-session.test.ts test/repository-bootstrap.test.ts test/repository-choice.test.ts test/onboarding-http.test.ts test/showcase-http.test.ts",
    "build": "tsc",
    "prepack": "pnpm build"
  },
  "devDependencies": {
    "@types/node": "22.19.17",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
